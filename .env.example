# ── vLLM inference endpoint ───────────────────────────────────────────────────
# Local dev default. Replace with the ngrok URL printed by colab_setup.ipynb
# when running inference on a Colab GPU.
VLLM_BASE_URL=http://localhost:8000
VLLM_MODEL_NAME=Qwen/Qwen2.5-1.5B-Instruct

# ── Dagster run/event storage (Docker only) ───────────────────────────────────
# Used by dagster.yaml → storage.postgres.postgres_url.
# Not needed for local dev (dagster dev uses SQLite in ~/.dagster).
DAGSTER_POSTGRES_URL=postgresql://dagster:dagster@postgres/dagster

# ── Ngrok tunnel (Colab only) ─────────────────────────────────────────────────
# Sign up at https://ngrok.com and paste your auth token here.
# Required when expose a Colab vLLM server to a local Dagster instance.
NGROK_AUTH_TOKEN=your_ngrok_auth_token_here
